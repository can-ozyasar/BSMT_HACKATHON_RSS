# BIOS Signal Radar — Environment Variables (Backend)
#
# Not: Backend `.env` dosyası `bios-signal-radar/backend` altında okunur.
# Kopyala: cp .env.example backend/.env

# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── App flags ─────────────────────────────────────────────────────────────────
DEMO_MODE=false

# ── Scoring thresholds ────────────────────────────────────────────────────────
SCORE_HIGH_THRESHOLD=80
SCORE_WATCH_THRESHOLD=65
SCORE_PARTNER_THRESHOLD=50

# ── Anomaly detection ─────────────────────────────────────────────────────────
ANOMALY_WINDOW_HOURS=6
ANOMALY_BASELINE_DAYS=7
ANOMALY_SPIKE_THRESHOLD=4.0

# ── Scheduler ─────────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=false
REFRESH_INTERVAL_MINUTES=30
